<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{.Title}} | agentic-news</title>
  <link rel="stylesheet" href="../assets/styles.css" />
</head>
<body>
  <main class="container">
    <a href="../index.html">← 返回</a>
    <article>
      <p class="meta">{{.Category}} · {{.SourceName}} · {{.PublishedAt}}</p>
      <h1>{{.Title}}</h1>
      {{if .CoverImage}}<img src="{{.CoverImage}}" alt="cover" class="cover" />{{end}}
      <p>{{.Summary}}</p>
      <p><strong>评分：</strong>{{.ScoreFinal}}</p>
      <p><strong>AI点评：</strong>{{.Viewpoint}}</p>
      <p><a href="{{.SourceURL}}" target="_blank" rel="noopener noreferrer">查看原文</a></p>
    </article>
  </main>
</body>
</html>
